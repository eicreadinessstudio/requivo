<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Datenschutzerklärung — Requivo</title>
  <link rel="icon" href="favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    :root{
      --bg:#f7f7f3;
      --bg-soft:#f1f3f0;
      --bg-panel:#fbfbf8;
      --line:#d8dde3;
      --line-soft:#e7ebe7;

      --text:#20242b;
      --text-soft:#64707c;
      --text-dim:#7d8792;

      --blue:#2e63ff;
      --blue-soft:#eaf1ff;

      --petrol-deep:#163a57;

      --shadow-soft:0 10px 24px rgba(17,24,39,0.04);
      --max:1240px;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      font-family:'Inter',sans-serif;
      background:var(--bg);
      color:var(--text);
      line-height:1.65;
      -webkit-font-smoothing:antialiased;
      text-rendering:optimizeLegibility;
    }

    .container{
      width:min(var(--max), calc(100% - 48px));
      margin:0 auto;
    }

    nav{
      position:sticky;
      top:0;
      z-index:20;
      background:rgba(247,247,243,.92);
      backdrop-filter:blur(10px);
      border-bottom:1px solid var(--line-soft);
    }

    .nav-inner{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:24px;
      padding:20px 0;
    }

    .logo{
      display:inline-flex;
      align-items:center;
      gap:12px;
      text-decoration:none;
      color:var(--text);
    }

    .logo-mark{
      width:14px;
      height:14px;
      border-radius:50%;
      background:var(--blue);
      flex:0 0 auto;
    }

    .logo-word{
      font-size:22px;
      line-height:1;
      letter-spacing:-.04em;
      font-weight:500;
      color:var(--text);
    }

    .nav-links{
      display:flex;
      align-items:center;
      gap:28px;
      flex-wrap:wrap;
    }

    .nav-links a{
      color:var(--text-soft);
      text-decoration:none;
      font-size:14px;
      font-weight:500;
      transition:color .18s ease;
    }

    .nav-links a:hover{color:var(--text)}

    .page{
      padding:72px 0 90px 0;
    }

    .eyebrow{
      font-size:12px;
      font-weight:800;
      letter-spacing:.18em;
      text-transform:uppercase;
      color:var(--blue);
      margin-bottom:18px;
    }

    h1{
      font-size:64px;
      line-height:.98;
      letter-spacing:-2.4px;
      font-weight:400;
      margin-bottom:18px;
      max-width:800px;
    }

    .intro{
      color:var(--text-soft);
      font-size:18px;
      line-height:1.8;
      max-width:780px;
      margin-bottom:42px;
    }

    .legal-card{
      background:#fff;
      border:1px solid var(--line);
      border-radius:22px;
      padding:34px;
      box-shadow:var(--shadow-soft);
    }

    .legal-section{
      padding:22px 0;
      border-bottom:1px solid var(--line-soft);
    }

    .legal-section:first-child{padding-top:0}
    .legal-section:last-child{
      padding-bottom:0;
      border-bottom:none;
    }

    h2{
      font-size:14px;
      line-height:1.2;
      letter-spacing:.14em;
      text-transform:uppercase;
      font-weight:800;
      color:var(--blue);
      margin-bottom:12px;
    }

    p, li{
      color:var(--text-soft);
      font-size:16px;
      line-height:1.85;
    }

    p{margin-bottom:10px}
    p:last-child{margin-bottom:0}

    ul{
      margin:8px 0 0 20px;
      padding:0;
    }

    li{margin-bottom:6px}

    strong{
      color:var(--text);
      font-weight:600;
    }

    a{
      color:var(--text);
      text-decoration:none;
      border-bottom:1px solid rgba(32,36,43,0.22);
      transition:border-color .18s ease, color .18s ease;
    }

    a:hover{
      color:var(--blue);
      border-color:rgba(46,99,255,0.35);
    }

    .back-link{
      display:inline-flex;
      align-items:center;
      gap:10px;
      margin-top:28px;
      color:var(--text-soft);
      text-decoration:none;
      border-bottom:none;
      font-size:14px;
      font-weight:600;
    }

    .back-link:hover{color:var(--text)}

    footer{
      background:var(--petrol-deep);
      color:#edf3f8;
      padding:54px 0 64px 0;
      border-top:1px solid rgba(255,255,255,0.08);
      margin-top:0;
    }

    .footer-grid{
      display:grid;
      grid-template-columns:1.1fr .8fr .8fr .9fr;
      gap:40px;
      align-items:start;
    }

    .footer-brand{
      display:flex;
      flex-direction:column;
      gap:18px;
    }

    .footer-logo{
      display:inline-flex;
      align-items:center;
      gap:12px;
      color:#ffffff;
      text-decoration:none;
    }

    .footer-logo .logo-mark{
      background:#d7e5f4;
    }

    .footer-logo .logo-word{
      color:#ffffff;
      font-size:26px;
    }

    .footer-brand p{
      color:#c7d4df;
      font-size:15px;
      line-height:1.8;
      max-width:360px;
    }

    .footer-col h4{
      font-size:12px;
      letter-spacing:.16em;
      text-transform:uppercase;
      font-weight:800;
      color:#9cb4c9;
      margin-bottom:16px;
    }

    .footer-col a,
    .footer-col p{
      display:block;
      color:#eef3f7;
      text-decoration:none;
      font-size:15px;
      line-height:1.9;
      opacity:.94;
      border-bottom:none;
    }

    .footer-col a:hover{opacity:1;color:#ffffff}

    .footer-bottom{
      margin-top:42px;
      padding-top:20px;
      border-top:1px solid rgba(255,255,255,0.12);
      color:#b8c8d6;
      font-size:13px;
    }

    @media (max-width:1100px){
      .footer-grid{grid-template-columns:1fr}
      h1{font-size:52px}
    }

    @media (max-width:820px){
      .container{width:min(var(--max), calc(100% - 32px))}
      .nav-inner{flex-direction:column;align-items:flex-start}
      .nav-links{gap:16px}
      .page{padding:54px 0 72px 0}
      h1{
        font-size:40px;
        line-height:1.02;
        letter-spacing:-1.4px;
      }
      .intro,p,li{font-size:16px}
      .legal-card{padding:24px}
    }
  </style>
</head>
